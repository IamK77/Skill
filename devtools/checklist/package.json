{
  "name": "skill-checklist",
  "version": "0.2.0",
  "description": "Flight checklist CLI for Claude Code skills",
  "bin": {
    "checklist": "bin/checklist.js"
  },
  "files": [
    "dist",
    "bin",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0"
}
